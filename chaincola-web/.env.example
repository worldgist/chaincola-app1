# Copy to .env.local and fill in from your Supabase project (Settings → API).
# Defaults also live in constants/supabase.json (same project as Expo app when not set).
NEXT_PUBLIC_SUPABASE_URL=https://woyvzsysasgvpigaflul.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-from-dashboard

# Server-only (scripts like import-users.js). Never expose in the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Wallet encryption: set CRYPTO_ENCRYPTION_KEY in Supabase → Project Settings →
# Edge Functions → Secrets (not here — Next.js must never ship this value to the browser).

# Alchemy Prices API — set ALCHEMY_API_KEY in Supabase → Edge Functions → Secrets
# (used by get-luno-prices, get-ethereum-price, get-solana-price, wallet balance helpers).
