# Copy to `.env.local` for local dev. Set the same keys in Vercel → Project → Settings → Environment Variables (Production / Preview).

# --- Required (browser Supabase client) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# --- Optional (only if you override defaults in code) ---
# NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# Server-only scripts (never expose to the browser; not needed for normal `next dev` / Vercel app runtime)
# SUPABASE_SERVICE_ROLE_KEY=
