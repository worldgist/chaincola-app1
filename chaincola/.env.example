# Optional: copy to .env in chaincola/ (loaded by app.config.js via dotenv).
# Same backend as chaincola-web — use the anon key from Supabase Dashboard → Settings → API.

EXPO_PUBLIC_SUPABASE_URL=https://woyvzsysasgvpigaflul.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Auth email links: Dashboard → Authentication → URL configuration → Redirect URLs
# Add every value printed by: npx expo config --json | findstr createURL
# plus chaincola://auth/callback (and exp://.../--/auth/callback for dev).

# Also accepted (shared with Next.js):
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Wallet private keys are encrypted on the SERVER by Edge Functions using
# CRYPTO_ENCRYPTION_KEY (Supabase Dashboard → Project Settings → Edge Functions → Secrets).
# Do NOT put CRYPTO_ENCRYPTION_KEY or any *_ENCRYPTION_KEY in this file — it would ship to clients.
